# Fabricate environment variables 
# ---------------------------------------------------
# — Copy to .env or .env.production and fill in values
# — Variables that are commented out are not needed by default
# — Database and Redis credentials need to be configured here or inside docker-compose.yml and provided by your secrets manager
# ---------------------------------------------------
# See https://docs.tonic.ai/fabricate for latest available settings before updating.
# ---------------------------------------------------

# ---------------------------------------------------
# Security Settings
# ---------------------------------------------------
SECRET_KEY_BASE="" # Run `docker run fabricate /fabricate/bin/rails secret` to generate new secret key and paste it here

# ---------------------------------------------------
# General Settings
# ---------------------------------------------------
FABRICATE_HOST="fabricate.localhost:3000" # Replace with the actual domain on which to host Fabricate (it must match the used domain, otherwise requests will be rejected)
FABRICATE_PROTOCOL=http # HTTP/HTTPS Listener protocol
FABRICATE_PORT=3000 # HTTP/s Listener port
FABRICATE_LOG_LEVEL="warn" # Log level (default is warn)
FABRICATE_DATA_DIR="/fabricate/data" # Directory where Fabricate stores generated datasets. This needs to match the volume mount in docker-compose.yml

# ---------------------------------------------------
# Organization and Admin email settings
# ---------------------------------------------------
FABRICATE_ADMIN_EMAIL="admin@fabricate.localhost" # Replace with the actual email address of the admin user (this user will receive access to the Admin Console after signing up)
FABRICATE_ORGANIZATION_NAME="My Company" # Replace with the actual name of the default account to assign all users to

# ---------------------------------------------------
# Email Settings
# ---------------------------------------------------
FABRICATE_MAIL_ADDRESS=""  # SMTP server hostname. Typically similar to "email-smtp.us-west-2.amazonaws.com" on AWS or smtp.gmail.com on Gmail
FABRICATE_MAIL_PORT="587" # SMTP port (typically 587 for TLS, 465 for SSL)
FABRICATE_MAIL_USER_NAME=""  # SMTP username. Typically similar to "AKIAIOSFODNN7EXAMPLE"
FABRICATE_MAIL_PASSWORD=""  # SMTP password. Typically similar to "wJarXUtnFMI/K7MDNG/bPxRfiCYEXAMPLEKEY"
FABRICATE_MAIL_FROM="no-reply@fabricate.localhost" # Email from address

# ---------------------------------------------------
# PostgreSQL Database Settings
# ---------------------------------------------------
FABRICATE_DATABASE_NAME="fabricate"
FABRICATE_DATABASE_USERNAME="fabricate"
FABRICATE_DATABASE_PASSWORD="change-me"
FABRICATE_DATABASE_HOST="db" # Host needs to match the service name in docker-compose.yml
FABRICATE_DATABASE_PORT="5432"
#FABRICATE_DB_POOL_SIZE=50 # Database connection pool size (default is 50)

# ---------------------------------------------------
# Redis Database Settings
# ---------------------------------------------------
FABRICATE_REDIS_PASSWORD="change-me" # Redis password for the Redis container.
FABRICATE_REDIS_URL="redis://:change-me@redis:6379" # Redis connection URL. Host needs to match the service name in docker-compose.yml

# ---------------------------------------------------
# PDF sidecar
# ---------------------------------------------------
FABRICATE_PDF_SOCKET_PATH="/fabricate/sockets/pdf.sock" # Unix socket path to communicate with the PDF sidecar. This needs to match the volume mount in docker-compose.yml
#FABRICATE_PDF_PORT=  # TCP port for the PDF sidecar (used when no socket path is set)
#FABRICATE_PDF_RENDER_TIMEOUT_MS=30000 # Timeout in milliseconds for PDF rendering (default is 30000)

# ---------------------------------------------------
# Storage (Active Storage)
# ----------------------------------------------------
FABRICATE_STORAGE_SERVICE=local # Local or S3-compatible storage service to use for generated data (local, amazon, azure, google)

# ---------------------------------------------------
# Amazon S3 Storage Settings (if FABRICATE_STORAGE_SERVICE="amazon")
# ----------------------------------------------------
# FABRICATE_S3_BUCKET="fabricate" # S3 bucket name. Change if needed
# FABRICATE_AWS_REGION="us-east-1" # Change if needed. Also used when the Claude LLM provider is Amazon Bedrock.
# FABRICATE_AWS_ACCESS_KEY_ID= # AWS access key ID. Either set these or assign an IAM role to the Fabricate EC2 instances
# FABRICATE_AWS_SECRET_ACCESS_KEY= # AWS secret access key. Either set these or assign an IAM role to the Fabricate EC2 instances

# ---------------------------------------------------
# Azure Blob Storage Settings (if FABRICATE_STORAGE_SERVICE="azure")
# ----------------------------------------------------
# FABRICATE_AZURE_STORAGE_ACCOUNT_NAME=  # Name of the Azure storage account
# FABRICATE_AZURE_STORAGE_ACCESS_KEY=  # Access key for the Azure account
# FABRICATE_AZURE_STORAGE_CONTAINER=  # Path to the Azure storage container to use

# ---------------------------------------------------
# Google Cloud Storage Settings (if FABRICATE_STORAGE_SERVICE="google")
# ----------------------------------------------------
# FABRICATE_GCS_PROJECT=  # Name of the Google Cloud Storage project to use
# FABRICATE_GCS_CREDENTIALS=  # Credentials to connect to the project
# FABRICATE_GCS_BUCKET=  # Name of the Google Cloud Storage bucket to use

# Optional - Set the signature version for Amazon S3-compatible services:
# Leave unset (default): Uses v4 signatures (AWS4-HMAC-SHA256) - Works with Amazon S3 and most modern Amazon S3-compatible services.
# Set to "2": Uses v2 signatures - Only needed for older Amazon S3-compatible services that don't support v4.
# FABRICATE_S3_SIGNATURE_VERSION=2
# FABRICATE_AWS_ENDPOINT=<your service endpoint> # Optional - Set this to use a service that is compatible with Amazon S3
# FABRICATE_S3_FORCE_PATH_STYLE=true # Optional - Set to true to use path-style addressing for services that are not compatible with Amazon S3

# ---------------------------------------------------
# Sign-in options
# ---------------------------------------------------

# Optional - Set these to allow users to sign in through GitHub
# GITHUB_CLIENT_ID=  # GitHub OAuth app client ID.
# GITHUB_CLIENT_SECRET=  # GitHub OAuth app client secret.

# Optional - Set these to enable users to sign in through Google
# GOOGLE_CLIENT_ID=  # Google OAuth 2.0 client ID.
# GOOGLE_CLIENT_SECRET=  # Google OAuth 2.0 client secret.

# Optional - Set these to allow users to sign in through Microsoft Entra ID (previously Azure)
# AZURE_CLIENT_ID=	# Microsoft Entra ID application (client) identifier
# AZURE_CLIENT_SECRET=	# Microsoft Entra ID client secret.
# AZURE_TENANT_ID= # Microsft Entra ID tenant ID.

# ---------------------------------------------------
# LLM provider
# ---------------------------------------------------

# Set if you're using Amazon Bedrock
# Also uses FABRICATE_AWS_REGION (see Amazon S3 settings above).
# FABRICATE_BEDROCK_REGION=   # Bedrock model region prefix to prepend to model IDs.
                                # For example, us.anthropic.claude-<model>.
                                # Defalt is global, to enable cross-region inference.
# FABRICATE_BEDROCK_API_KEY=  # API key for Amazon Bedrock

# Set if you're using Anthropic
# FABRICATE_ANTHROPIC_BASE_URL=  # URL to connect to Anthropic
# FABRICATE_ANTHROPIC_API_KEY=   # API key for Anthropic

# Set if you're using Azure AI Foundry
# FABRICATE_AZURE_URI=     # Base URL for Azure AI Foundry Anthropic-compatible endpoint.
# FABRICATE_AZURE_API_KEY= # API key for the Azure AI Foundry endpoint.

# Set if you're using Google Gemini Enterprise Agent Platform (formerly Vertex AI)
# FABRICATE_VERTEXAI_PROJECT_ID=  # Google Cloud project ID (required). Falls back to GOOGLE_CLOUD_PROJECT.
# FABRICATE_VERTEXAI_GOOGLE_CLOUD_LOCATION=  # Vertex AI region (required). Falls back to GOOGLE_CLOUD_LOCATION.
# FABRICATE_VERTEXAI_SERVICE_ACCOUNT_KEY=  # Service account JSON key. Falls back to VERTEXAI_SERVICE_ACCOUNT_KEY.

# ---------------------------------------------------
# LLM provider for rule-based AI functions
# ---------------------------------------------------
#FABRICATE_LLM_PROVIDER=openai # LLM provider to use for rule-based AI functions (openai, azure, ollama)
#FABRICATE_LLM_URI=  # Base URI for the API endpoint. 
#FABRICATE_LLM_API_KEY=  # API key for the selected LLM provider.
#FABRICATE_LLM_API_VERSION=  # Azure OpenAI API version (only configure if provider is azure)
#FABRICATE_LLM_TEXT_GEN_CONCURRENCY=10 # Maximum concurrent LLM requests for text generation (default is 10)

# ---------------------------------------------------
# Sidekiq worker concurrency
# ---------------------------------------------------
#FABRICATE_SIDEKIQ_CONCURRENCY=50 # Maximum concurrent Sidekiq worker processes. This needs to be lower than connection pool size in FABRICATE_DB_POOL_SIZE.